@model IEnumerable<PropertyLeasingAPI.Models.Tenant>

@{
    ViewData["Title"] = "Tenants";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>👥 Tenants</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Tenant</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>National ID</th>
                    <th>Linked User</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.NationalId</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.UserId))
                            {
                                <span class="badge bg-success">Linked</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No login</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.TenantId" class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.TenantId" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.TenantId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <p class="text-muted text-center py-4">No tenants found.</p>
        }
    </div>
</div>

