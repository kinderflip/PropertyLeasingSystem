@model PropertyLeasingMVC.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📊 Dashboard</h2>
    <span class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
</div>

@if (Model.Role == "PropertyManager")
{
    <!-- Manager view: global portfolio stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-2">
            <div class="card text-white bg-primary h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.TotalProperties</h1>
                    <p class="mb-0">Properties</p>
                    <small class="text-white-50">@Model.StandaloneProperties standalone · @Model.MultiUnitProperties multi-unit</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-secondary h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.TotalUnits</h1>
                    <p class="mb-0">Units</p>
                    <small class="text-white-50">@Model.AvailableUnits available</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-success h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.AvailableProperties</h1>
                    <p class="mb-0">Available</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-info h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.TotalTenants</h1>
                    <p class="mb-0">Tenants</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-dark h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.ActiveLeases</h1>
                    <p class="mb-0">Active Leases</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-danger h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.PendingMaintenance</h1>
                    <p class="mb-0">Pending Maintenance</p>
                </div>
            </div>
        </div>
    </div>
}
else if (Model.Role == "MaintenanceStaff")
{
    <!-- Staff view: personal workload -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-info h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.AssignedToMe</h1>
                    <p class="mb-0">Assigned to me</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-primary h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.InProgressByMe</h1>
                    <p class="mb-0">In progress</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.CompletedByMe</h1>
                    <p class="mb-0">Completed by me</p>
                </div>
            </div>
        </div>
    </div>
}
else if (Model.Role == "Tenant")
{
    <!-- Tenant view: my leases & requests -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-dark h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.MyActiveLeases</h1>
                    <p class="mb-0">My active leases</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.MyOpenRequests</h1>
                    <p class="mb-0">My open requests</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-danger h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.MyOverduePayments</h1>
                    <p class="mb-0">Overdue payments</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Guest view: invite to browse / register -->
    <div class="row g-3 mb-4 justify-content-center">
        <div class="col-md-4">
            <div class="card text-white bg-success h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.AvailableUnits</h1>
                    <p class="mb-0">Units available now</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-primary h-100 shadow-sm">
                <div class="card-body text-center">
                    <h1 class="display-5 fw-bold">@Model.AvailableProperties</h1>
                    <p class="mb-0">Available properties</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mt-4">
        <div class="col-md-8 text-center">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h3>Welcome to Property Leasing System</h3>
                    <p class="text-muted">Browse available units, submit a maintenance request, or register as a tenant to apply for a lease.</p>
                    <a asp-controller="Units" asp-action="Browse" class="btn btn-success me-2">🏢 Browse Units</a>
                    <a asp-controller="Track" asp-action="Index" class="btn btn-outline-secondary me-2">🔍 Track Request</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary me-2">Login</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary">Register</a>
                </div>
            </div>
        </div>
    </div>
}

@if (User.Identity!.IsAuthenticated)
{
    <div class="row g-3">
        <!-- Recent Maintenance Requests -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white d-flex justify-content-between">
                    <span>🔧 @(Model.Role == "MaintenanceStaff" ? "My Requests" : "Recent Maintenance Requests")</span>
                    <a asp-controller="MaintenanceRequests" asp-action="Index"
                       class="text-white text-decoration-none small">View All →</a>
                </div>
                <div class="card-body p-0">
                    @if (Model.RecentRequests.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Title</th>
                                    <th>Property / Unit</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var req in Model.RecentRequests)
                                {
                                    <tr>
                                        <td>@req.Title</td>
                                        <td>
                                            @req.Property?.Address
                                            @if (req.Unit != null)
                                            {
                                                <span class="badge bg-info ms-1">Unit @req.Unit.UnitNumber</span>
                                            }
                                        </td>
                                        <td>
                                            @{
                                                var reqBadge = req.Status switch
                                                {
                                                    PropertyLeasingAPI.Models.MaintenanceStatus.Submitted => "bg-warning text-dark",
                                                    PropertyLeasingAPI.Models.MaintenanceStatus.Assigned => "bg-info",
                                                    PropertyLeasingAPI.Models.MaintenanceStatus.InProgress => "bg-primary",
                                                    PropertyLeasingAPI.Models.MaintenanceStatus.Resolved => "bg-success",
                                                    PropertyLeasingAPI.Models.MaintenanceStatus.Closed => "bg-dark",
                                                    _ => "bg-secondary"
                                                };
                                            }
                                            <span class="badge @reqBadge">@req.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">No maintenance requests yet.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Leases -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between">
                    <span>📋 @(Model.Role == "Tenant" ? "My Leases" : "Recent Leases")</span>
                    <a asp-controller="Leases" asp-action="Index"
                       class="text-white text-decoration-none small">View All →</a>
                </div>
                <div class="card-body p-0">
                    @if (Model.RecentLeases.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tenant</th>
                                    <th>Property / Unit</th>
                                    <th>Rent</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var lease in Model.RecentLeases)
                                {
                                    <tr>
                                        <td>@lease.Tenant?.FullName</td>
                                        <td>
                                            @lease.Property?.Address
                                            @if (lease.Unit != null)
                                            {
                                                <span class="badge bg-info ms-1">Unit @lease.Unit.UnitNumber</span>
                                            }
                                        </td>
                                        <td>@lease.MonthlyRent.ToString("N3") BD</td>
                                        <td>
                                            @if (lease.Status == PropertyLeasingAPI.Models.LeaseStatus.Active)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else if (lease.Status == PropertyLeasingAPI.Models.LeaseStatus.Expired)
                                            {
                                                <span class="badge bg-secondary">Expired</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">@lease.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">No leases yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model.Role == "PropertyManager")
    {
        <!-- Manager Quick Actions -->
        <div class="row g-3 mt-2">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header">⚡ Quick Actions</div>
                    <div class="card-body">
                        <a asp-controller="Properties" asp-action="Create"
                           class="btn btn-primary me-2">+ Add Property</a>
                        <a asp-controller="Tenants" asp-action="Create"
                           class="btn btn-info me-2">+ Add Tenant</a>
                        <a asp-controller="Leases" asp-action="Create"
                           class="btn btn-dark me-2">+ New Lease</a>
                        <a asp-controller="MaintenanceRequests" asp-action="Create"
                           class="btn btn-danger me-2">+ Maintenance Request</a>
                        <a asp-controller="Payments" asp-action="Create"
                           class="btn btn-success">+ Record Payment</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (Model.Role == "Tenant")
    {
        <div class="row g-3 mt-2">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header">⚡ Quick Actions</div>
                    <div class="card-body">
                        <a asp-controller="Units" asp-action="Browse" class="btn btn-success me-2">🏢 Browse Units</a>
                        <a asp-controller="MaintenanceRequests" asp-action="Create" class="btn btn-danger me-2">+ New Maintenance Request</a>
                        <a asp-controller="Leases" asp-action="Create" class="btn btn-dark">+ Apply for Lease</a>
                    </div>
                </div>
            </div>
        </div>
    }
}
