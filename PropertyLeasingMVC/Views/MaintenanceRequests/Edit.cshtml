@model PropertyLeasingAPI.Models.MaintenanceRequest
@{
    ViewData["Title"] = "Edit Maintenance Request";
}

<h2>Edit Maintenance Request</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <input type="hidden" asp-for="RequestId" />
            <input type="hidden" asp-for="DateSubmitted" />
            <input type="hidden" asp-for="DateAssigned" />
            <input type="hidden" asp-for="DateResolved" />

            <div class="mb-3">
                <label asp-for="PropertyId" class="form-label">Property</label>
                <select asp-for="PropertyId" asp-items="ViewBag.PropertyId" class="form-control">
                    <option value="">-- Select Property --</option>
                </select>
                <span asp-validation-for="PropertyId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TenantId" class="form-label">Tenant</label>
                <select asp-for="TenantId" asp-items="ViewBag.TenantId" class="form-control">
                    <option value="">-- Select Tenant --</option>
                </select>
                <span asp-validation-for="TenantId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Category" class="form-label"></label>
                <select asp-for="Category"
                        asp-items="Html.GetEnumSelectList<PropertyLeasingAPI.Models.MaintenanceCategory>()"
                        class="form-control">
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Priority" class="form-label"></label>
                <select asp-for="Priority"
                        asp-items="Html.GetEnumSelectList<PropertyLeasingAPI.Models.MaintenancePriority>()"
                        class="form-control">
                </select>
                <span asp-validation-for="Priority" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status"
                        asp-items="Html.GetEnumSelectList<PropertyLeasingAPI.Models.MaintenanceStatus>()"
                        class="form-control">
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AssignedStaffId" class="form-label">Assigned Staff</label>
                <select asp-for="AssignedStaffId" asp-items="ViewBag.AssignedStaffId" class="form-control">
                    <option value="">-- Unassigned --</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="StaffNotes" class="form-label"></label>
                <textarea asp-for="StaffNotes" class="form-control" rows="2" placeholder="Notes about the work done..."></textarea>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-warning">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
