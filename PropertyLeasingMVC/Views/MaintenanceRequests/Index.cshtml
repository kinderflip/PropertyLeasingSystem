@model IEnumerable<PropertyLeasingAPI.Models.MaintenanceRequest>
@{
    ViewData["Title"] = "Maintenance Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🔧 Maintenance Requests</h2>
    @if (User.IsInRole("PropertyManager") || User.IsInRole("Tenant"))
    {
        <a asp-action="Create" class="btn btn-danger">+ New Request</a>
    }
</div>

<!-- Live update notification area -->
<div id="signalr-notification" class="alert alert-info d-none" role="alert">
    <strong>🔔 Live Update:</strong> <span id="notification-text"></span>
</div>

<!-- Search & Filter Form -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2">
            <div class="col-md-4">
                <input type="text" name="searchString" value="@ViewBag.SearchString"
                       class="form-control" placeholder="Search by title or description..." />
            </div>
            <div class="col-md-3">
                <select name="status" class="form-control">
                    <option value="">-- All Statuses --</option>
                    <option value="0" selected="@(ViewBag.Status == PropertyLeasingAPI.Models.MaintenanceStatus.Pending)">Pending</option>
                    <option value="1" selected="@(ViewBag.Status == PropertyLeasingAPI.Models.MaintenanceStatus.InProgress)">In Progress</option>
                    <option value="2" selected="@(ViewBag.Status == PropertyLeasingAPI.Models.MaintenanceStatus.Completed)">Completed</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="category" class="form-control">
                    <option value="">-- All Categories --</option>
                    <option value="0" selected="@(ViewBag.Category == PropertyLeasingAPI.Models.MaintenanceCategory.Plumbing)">Plumbing</option>
                    <option value="1" selected="@(ViewBag.Category == PropertyLeasingAPI.Models.MaintenanceCategory.Electrical)">Electrical</option>
                    <option value="2" selected="@(ViewBag.Category == PropertyLeasingAPI.Models.MaintenanceCategory.HVAC)">HVAC</option>
                    <option value="3" selected="@(ViewBag.Category == PropertyLeasingAPI.Models.MaintenanceCategory.General)">General</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-danger w-100">Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="maintenance-table">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Property</th>
                    <th>Tenant</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th>Date Submitted</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr id="row-@item.RequestId">
                        <td>@item.Title</td>
                        <td>@item.Property?.Address</td>
                        <td>@item.Tenant?.FullName</td>
                        <td>@item.Category</td>
                        <td>
                            <span class="badge @(item.Status == PropertyLeasingAPI.Models.MaintenanceStatus.Pending ? "bg-warning" :
                                                                                 item.Status == PropertyLeasingAPI.Models.MaintenanceStatus.InProgress ? "bg-info" :
                                                                                 "bg-success")"
                              id="status-@item.RequestId">
                            @item.Status
                        </span>
                    </td>
                    <td>@item.DateSubmitted.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.RequestId"
                           class="btn btn-sm btn-outline-primary">Details</a>
                        @if (User.IsInRole("PropertyManager") || User.IsInRole("MaintenanceStaff"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.RequestId"
                                   class="btn btn-sm btn-outline-warning">Edit</a>
                            }
                            @if (User.IsInRole("PropertyManager"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.RequestId"
                                   class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <p class="text-muted text-center py-4">No maintenance requests found.</p>
        }
    </div>
</div>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/maintenanceHub")
            .build();

        connection.on("ReceiveStatusUpdate", function (requestId, status, title) {
            const badge = document.getElementById("status-" + requestId);
            if (badge) {
                badge.innerText = status;
                badge.className = "badge " + getStatusClass(status);
            }

            const notification = document.getElementById("signalr-notification");
            const text = document.getElementById("notification-text");
            text.innerText = '"' + title + '" status changed to ' + status;
            notification.classList.remove("d-none");

            setTimeout(() => notification.classList.add("d-none"), 5000);
        });

        function getStatusClass(status) {
            if (status === "Pending") return "bg-warning";
            if (status === "InProgress") return "bg-info";
            if (status === "Completed") return "bg-success";
            return "bg-secondary";
        }

        connection.start().catch(err => console.error(err.toString()));
    </script>
}