@model PropertyLeasingAPI.Models.MaintenanceRequest
@{
    ViewData["Title"] = "New Maintenance Request";
}

<h2>New Maintenance Request</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="PropertyId" class="form-label">Property</label>
                <select asp-for="PropertyId" asp-items="ViewBag.PropertyId" class="form-control" id="PropertyId">
                    <option value="">-- Select Property --</option>
                </select>
                <span asp-validation-for="PropertyId" class="text-danger"></span>
            </div>

            <div class="mb-3" id="unit-row">
                <label asp-for="UnitId" class="form-label">Unit</label>
                <select asp-for="UnitId" class="form-control" id="UnitId">
                    <option value="">-- Select a property first --</option>
                </select>
                <small class="text-muted" id="unit-help">Required for multi-unit properties. Leave blank for standalone properties.</small>
                <span asp-validation-for="UnitId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TenantId" class="form-label">Tenant</label>
                <select asp-for="TenantId" asp-items="ViewBag.TenantId" class="form-control">
                    <option value="">-- Select Tenant --</option>
                </select>
                <span asp-validation-for="TenantId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="Brief title of the issue" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Describe the issue in detail"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Category" class="form-label"></label>
                <select asp-for="Category"
                        asp-items="Html.GetEnumSelectList<PropertyLeasingAPI.Models.MaintenanceCategory>()"
                        class="form-control">
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Priority" class="form-label"></label>
                <select asp-for="Priority"
                        asp-items="Html.GetEnumSelectList<PropertyLeasingAPI.Models.MaintenancePriority>()"
                        class="form-control">
                </select>
                <span asp-validation-for="Priority" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-danger">Submit Request</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            var $prop = document.getElementById('PropertyId');
            var $unit = document.getElementById('UnitId');
            var $row = document.getElementById('unit-row');
            var $help = document.getElementById('unit-help');

            if (!$prop || !$unit) return;

            function reset(msg) {
                $unit.innerHTML = '<option value="">' + msg + '</option>';
            }

            function loadUnits(propertyId) {
                if (!propertyId) {
                    reset('-- Select a property first --');
                    $row.style.display = '';
                    if ($help) $help.textContent = 'Required for multi-unit properties. Leave blank for standalone properties.';
                    return;
                }
                reset('-- Loading... --');
                fetch('/Units/ForPropertyJson?propertyId=' + encodeURIComponent(propertyId))
                    .then(function (r) { return r.ok ? r.json() : []; })
                    .then(function (units) {
                        if (!units || units.length === 0) {
                            reset('-- No units (standalone property) --');
                            $row.style.display = 'none';
                            $unit.value = '';
                            if ($help) $help.textContent = 'Standalone property — no unit required.';
                            return;
                        }
                        $row.style.display = '';
                        var html = '<option value="">-- Select Unit --</option>';
                        for (var i = 0; i < units.length; i++) {
                            var u = units[i];
                            html += '<option value="' + u.unitId + '">' + u.unitNumber + ' (' + u.unitType + ')</option>';
                        }
                        $unit.innerHTML = html;
                        if ($help) $help.textContent = 'Select a unit from this multi-unit property.';
                    })
                    .catch(function () { reset('-- Error loading units --'); });
            }

            $prop.addEventListener('change', function () {
                loadUnits($prop.value);
            });

            if ($prop.value) loadUnits($prop.value);
        })();
    </script>
}
