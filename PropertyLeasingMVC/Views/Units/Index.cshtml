@model IEnumerable<PropertyLeasingAPI.Models.Unit>
@{
    ViewData["Title"] = "Units";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>🏢 Units</h2>
        @if (ViewBag.PropertyName != null)
        {
            <p class="text-muted mb-0">Filtered to: @ViewBag.PropertyName</p>
        }
    </div>
    @if (User.IsInRole("PropertyManager"))
    {
        <a asp-action="Create" asp-route-propertyId="@ViewBag.PropertyId" class="btn btn-primary">+ Add Unit</a>
    }
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2">
            <input type="hidden" name="propertyId" value="@ViewBag.PropertyId" />
            <div class="col-md-4">
                <select name="status" class="form-control">
                    <option value="">-- All Statuses --</option>
                    <option value="0" selected="@(ViewBag.Status == PropertyLeasingAPI.Models.UnitStatus.Available)">Available</option>
                    <option value="1" selected="@(ViewBag.Status == PropertyLeasingAPI.Models.UnitStatus.Leased)">Leased</option>
                    <option value="2" selected="@(ViewBag.Status == PropertyLeasingAPI.Models.UnitStatus.UnderMaintenance)">Under Maintenance</option>
                </select>
            </div>
            <div class="col-md-4">
                <select name="type" class="form-control">
                    <option value="">-- All Types --</option>
                    <option value="0" selected="@(ViewBag.Type == PropertyLeasingAPI.Models.UnitType.Studio)">Studio</option>
                    <option value="1" selected="@(ViewBag.Type == PropertyLeasingAPI.Models.UnitType.OneBedroom)">1 Bedroom</option>
                    <option value="2" selected="@(ViewBag.Type == PropertyLeasingAPI.Models.UnitType.TwoBedroom)">2 Bedroom</option>
                    <option value="3" selected="@(ViewBag.Type == PropertyLeasingAPI.Models.UnitType.ThreeBedroom)">3 Bedroom</option>
                    <option value="4" selected="@(ViewBag.Type == PropertyLeasingAPI.Models.UnitType.Office)">Office</option>
                    <option value="5" selected="@(ViewBag.Type == PropertyLeasingAPI.Models.UnitType.Shop)">Shop</option>
                    <option value="6" selected="@(ViewBag.Type == PropertyLeasingAPI.Models.UnitType.Other)">Other</option>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Unit #</th>
                    <th>Property</th>
                    <th>Type</th>
                    <th>Size (sqm)</th>
                    <th>Rent</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td><strong>@u.UnitNumber</strong></td>
                        <td>@u.Property?.Address, @u.Property?.City</td>
                        <td>@u.UnitType</td>
                        <td>@u.SizeSqm.ToString("N2")</td>
                        <td>@u.MonthlyRent.ToString("N3") BD</td>
                        <td>
                            @if (u.Status == PropertyLeasingAPI.Models.UnitStatus.Available)
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else if (u.Status == PropertyLeasingAPI.Models.UnitStatus.Leased)
                            {
                                <span class="badge bg-warning">Leased</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Under Maintenance</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@u.UnitId" class="btn btn-sm btn-outline-primary">Details</a>
                            @if (User.IsInRole("PropertyManager"))
                            {
                                <a asp-action="Edit" asp-route-id="@u.UnitId" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@u.UnitId" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <p class="text-muted text-center py-4">No units match these filters.</p>
        }
    </div>
</div>
