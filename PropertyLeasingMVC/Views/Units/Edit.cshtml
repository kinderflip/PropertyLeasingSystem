@model PropertyLeasingAPI.Models.Unit
@{
    ViewData["Title"] = $"Edit Unit {Model.UnitNumber}";
}

<h2>✏️ Edit Unit @Model.UnitNumber</h2>

<form asp-action="Edit" method="post" class="card shadow-sm">
    <input type="hidden" asp-for="UnitId" />
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="PropertyId" class="form-label">Property</label>
            <select asp-for="PropertyId" asp-items="ViewBag.PropertyId" class="form-control"></select>
            <span asp-validation-for="PropertyId" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="UnitNumber" class="form-label"></label>
                <input asp-for="UnitNumber" class="form-control" />
                <span asp-validation-for="UnitNumber" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="UnitType" class="form-label"></label>
                <select asp-for="UnitType" class="form-control">
                    <option value="0">Studio</option>
                    <option value="1">1 Bedroom</option>
                    <option value="2">2 Bedroom</option>
                    <option value="3">3 Bedroom</option>
                    <option value="4">Office</option>
                    <option value="5">Shop</option>
                    <option value="6">Other</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="0">Available</option>
                    <option value="1">Leased</option>
                    <option value="2">Under Maintenance</option>
                </select>
            </div>

            <div class="col-md-4">
                <label asp-for="SizeSqm" class="form-label">Size (sqm)</label>
                <input asp-for="SizeSqm" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="SizeSqm" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="MonthlyRent" class="form-label">Monthly rent (BD)</label>
                <input asp-for="MonthlyRent" type="number" step="0.001" class="form-control" />
                <span asp-validation-for="MonthlyRent" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Amenities" class="form-label"></label>
                <input asp-for="Amenities" class="form-control" />
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <a asp-action="Index" asp-route-propertyId="@Model.PropertyId" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
