@model PropertyLeasingAPI.Models.Unit
@{
    ViewData["Title"] = $"Delete Unit {Model.UnitNumber}";
}

<h2>🗑️ Delete Unit @Model.UnitNumber</h2>

<div class="alert alert-warning">Are you sure you want to delete this unit? This cannot be undone.</div>

<dl class="row">
    <dt class="col-sm-3">Property</dt>
    <dd class="col-sm-9">@Model.Property?.Address, @Model.Property?.City</dd>

    <dt class="col-sm-3">Unit number</dt>
    <dd class="col-sm-9">@Model.UnitNumber</dd>

    <dt class="col-sm-3">Type</dt>
    <dd class="col-sm-9">@Model.UnitType</dd>

    <dt class="col-sm-3">Monthly rent</dt>
    <dd class="col-sm-9">@Model.MonthlyRent.ToString("N3") BD</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UnitId" />
    <a asp-action="Index" asp-route-propertyId="@Model.PropertyId" class="btn btn-secondary">Cancel</a>
    <button type="submit" class="btn btn-danger">Delete</button>
</form>
