@model PropertyLeasingAPI.Models.Lease
@{
    ViewData["Title"] = "Apply for Lease";
}

<h2>Apply for Lease</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="PropertyId" class="form-label">Property</label>
                <select asp-for="PropertyId" asp-items="ViewBag.PropertyId" class="form-control" id="PropertyId">
                    <option value="">-- Select Available Property --</option>
                </select>
                <span asp-validation-for="PropertyId" class="text-danger"></span>
            </div>

            <div class="mb-3" id="unit-row">
                <label asp-for="UnitId" class="form-label">Unit</label>
                <select asp-for="UnitId" class="form-control" id="UnitId">
                    <option value="">-- Select a property first --</option>
                </select>
                <small class="text-muted" id="unit-help">Required for multi-unit properties. Leave blank for standalone properties.</small>
                <span asp-validation-for="UnitId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TenantId" class="form-label">Tenant</label>
                <select asp-for="TenantId" asp-items="ViewBag.TenantId" class="form-control">
                    <option value="">-- Select Tenant --</option>
                </select>
                <span asp-validation-for="TenantId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StartDate" class="form-label"></label>
                <input asp-for="StartDate" class="form-control" type="date" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EndDate" class="form-label"></label>
                <input asp-for="EndDate" class="form-control" type="date" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MonthlyRent" class="form-label"></label>
                <input asp-for="MonthlyRent" class="form-control" />
                <span asp-validation-for="MonthlyRent" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ApplicationNotes" class="form-label"></label>
                <textarea asp-for="ApplicationNotes" class="form-control" rows="3"
                          placeholder="Any additional notes for the application..."></textarea>
                <span asp-validation-for="ApplicationNotes" class="text-danger"></span>
            </div>

            <div class="alert alert-info">
                <strong>Note:</strong> This will submit a lease application. The Property Manager will review and process your application through the screening workflow.
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-dark">Submit Application</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        (function () {
            var $prop = document.getElementById('PropertyId');
            var $unit = document.getElementById('UnitId');
            var $row = document.getElementById('unit-row');
            var $help = document.getElementById('unit-help');
            var $rent = document.getElementById('MonthlyRent');

            if (!$prop || !$unit) return;

            function reset(msg) {
                $unit.innerHTML = '<option value="">' + msg + '</option>';
            }

            function loadUnits(propertyId) {
                if (!propertyId) {
                    reset('-- Select a property first --');
                    $row.style.display = '';
                    if ($help) $help.textContent = 'Required for multi-unit properties. Leave blank for standalone properties.';
                    return;
                }
                reset('-- Loading... --');
                fetch('/Units/ForPropertyJson?propertyId=' + encodeURIComponent(propertyId))
                    .then(function (r) { return r.ok ? r.json() : []; })
                    .then(function (units) {
                        if (!units || units.length === 0) {
                            // Standalone property: hide the unit row
                            reset('-- No units (standalone property) --');
                            $row.style.display = 'none';
                            $unit.value = '';
                            if ($help) $help.textContent = 'Standalone property — no unit required.';
                            return;
                        }
                        $row.style.display = '';
                        var html = '<option value="">-- Select Unit --</option>';
                        for (var i = 0; i < units.length; i++) {
                            var u = units[i];
                            var label = u.unitNumber + ' (' + u.unitType + ') - ' + Number(u.monthlyRent).toFixed(3) + ' BD';
                            if (u.status && u.status !== 'Available') {
                                label += ' [' + u.status + ']';
                            }
                            html += '<option value="' + u.unitId + '" data-rent="' + u.monthlyRent + '">' + label + '</option>';
                        }
                        $unit.innerHTML = html;
                        if ($help) $help.textContent = 'Select a unit from this multi-unit property.';
                    })
                    .catch(function () { reset('-- Error loading units --'); });
            }

            $prop.addEventListener('change', function () {
                loadUnits($prop.value);
            });

            $unit.addEventListener('change', function () {
                var opt = $unit.options[$unit.selectedIndex];
                var rent = opt ? opt.getAttribute('data-rent') : null;
                if (rent && $rent && !$rent.value) {
                    $rent.value = rent;
                }
            });

            // Initial load (in case a property is preselected, e.g. validation re-render)
            if ($prop.value) loadUnits($prop.value);
        })();
    </script>
}
