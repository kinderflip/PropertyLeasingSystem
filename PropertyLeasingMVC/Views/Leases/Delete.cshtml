@model PropertyLeasingAPI.Models.Lease
@{
    ViewData["Title"] = "Delete Lease";
}

<h2>Delete Lease</h2>
<h5 class="text-danger">Are you sure you want to delete this lease?</h5>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Property</dt>
            <dd class="col-sm-9">@Model.Property?.Address</dd>

            <dt class="col-sm-3">Tenant</dt>
            <dd class="col-sm-9">@Model.Tenant?.FullName (@Model.Tenant?.Email)</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3">Monthly Rent</dt>
            <dd class="col-sm-9">@Model.MonthlyRent.ToString("N3") BD</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary">@Model.Status</span></dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="LeaseId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
</form>
