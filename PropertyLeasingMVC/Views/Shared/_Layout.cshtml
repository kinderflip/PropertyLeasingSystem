<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Property Leasing System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PropertyLeasingMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    🏠 Property Leasing
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <!-- Left side links -->
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <!-- Track Request + Browse Units - visible to everyone, no login needed -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Track" asp-action="Index">🔍 Track Request</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Units" asp-action="Browse">🏢 Browse Units</a>
                        </li>

                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Properties" asp-action="Index">Properties</a>
                            </li>

                            @* Role-scoped nav: each role only sees links it is authorized to use. *@
                            @if (User.IsInRole("PropertyManager"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Units" asp-action="Index">Units</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Tenants" asp-action="Index">Tenants</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Leases" asp-action="Index">Leases</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="MaintenanceRequests" asp-action="Index">Maintenance</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Payments" asp-action="Index">Payments</a>
                                </li>
                            }
                            else if (User.IsInRole("MaintenanceStaff"))
                            {
                                @* M5: staff only get the maintenance board, not leasing/tenant data. *@
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="MaintenanceRequests" asp-action="Index">Maintenance</a>
                                </li>
                            }
                            else if (User.IsInRole("Tenant"))
                            {
                                @* M5: Tenant role only sees their own data via dedicated actions. *@
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Leases" asp-action="MyLeases">My Leases</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Payments" asp-action="MyPayments">My Payments</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="MaintenanceRequests" asp-action="Index">My Requests</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link position-relative" asp-controller="Notifications" asp-action="Index">
                                    Notifications
                                    @{
                                        var notifContext = ViewContext.HttpContext.RequestServices.GetService(typeof(PropertyLeasingAPI.Data.AppDbContext)) as PropertyLeasingAPI.Data.AppDbContext;
                                        var currentUserId = ViewContext.HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                        if (notifContext != null && currentUserId != null)
                                        {
                                            var unreadCount = notifContext.Notifications.Count(n => n.UserId == currentUserId && !n.IsRead);
                                            if (unreadCount > 0)
                                            {
                                                <span class="badge bg-danger rounded-pill">@unreadCount</span>
                                            }
                                        }
                                    }
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Right side: login/logout -->
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-warning fw-bold">
                                    👤 @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-outline-light btn-sm mt-1">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <!-- Success/Error TempData messages -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; 2026 - Property Leasing System - Bahrain Polytechnic
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity!.IsAuthenticated)
    {
        <!-- L11: live notification listener — pops a toast when CreateNotification fires -->
        <div id="notif-toast-region"
             class="position-fixed top-0 end-0 p-3"
             style="z-index: 1080;"></div>

        <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
        <script>
            (function () {
                var conn = new signalR.HubConnectionBuilder()
                    .withUrl("/notificationHub")
                    .withAutomaticReconnect()
                    .build();

                conn.on("ReceiveNotification", function (n) {
                    // Bump the navbar bell badge (or create one if it isn't there yet).
                    var navLink = document.querySelector('a[href="/Notifications"]');
                    if (navLink) {
                        var badge = navLink.querySelector('.badge');
                        if (badge) {
                            var current = parseInt(badge.innerText, 10) || 0;
                            badge.innerText = current + 1;
                        } else {
                            var span = document.createElement('span');
                            span.className = 'badge bg-danger rounded-pill';
                            span.innerText = '1';
                            navLink.appendChild(document.createTextNode(' '));
                            navLink.appendChild(span);
                        }
                    }

                    // Toast popup (vanilla — no extra deps).
                    var region = document.getElementById('notif-toast-region');
                    if (!region) return;
                    var toast = document.createElement('div');
                    toast.className = 'toast align-items-center text-bg-info border-0 show mb-2';
                    toast.setAttribute('role', 'alert');
                    var safeTitle = (n.title || 'Notification').toString().replace(/[<>]/g, '');
                    var safeMsg   = (n.message || '').toString().replace(/[<>]/g, '');
                    toast.innerHTML =
                        '<div class="d-flex">' +
                            '<div class="toast-body">' +
                                '<strong>' + safeTitle + '</strong><br>' +
                                '<small>' + safeMsg + '</small>' +
                            '</div>' +
                            '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                        '</div>';
                    region.appendChild(toast);
                    setTimeout(function () { toast.remove(); }, 6000);
                });

                conn.start().catch(function (err) { console.error('NotificationHub:', err); });
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>