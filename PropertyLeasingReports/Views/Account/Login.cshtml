@{
    ViewData["Title"] = "Login - Reports";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-dark text-white text-center py-4">
                <h4>📊 Property Leasing Reports</h4>
                <p class="mb-0 text-muted">Sign in to access reports</p>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control"
                               placeholder="Enter your email" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control"
                               placeholder="Enter your password" required />
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-dark btn-lg">Sign In</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center text-muted">
                <small>Property Leasing System — Reporting Portal</small>
            </div>
        </div>
    </div>
</div>