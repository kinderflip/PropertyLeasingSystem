@model List<PropertyLeasingReports.Models.MaintenanceReport>
@{
    ViewData["Title"] = "Maintenance Report";
    // Updated to match new MaintenanceStatus enum: Submitted=0, Assigned=1, InProgress=2, Resolved=3, Closed=4
    var statusNames = new[] { "Submitted", "Assigned", "In Progress", "Resolved", "Closed" };
    var statusColors = new[] { "warning", "info", "primary", "success", "secondary" };
    var categoryNames = new[] { "Plumbing", "Electrical", "HVAC", "General" };
    var priorityNames = new[] { "Low", "Medium", "High", "Urgent" };
    var priorityColors = new[] { "secondary", "info", "warning", "danger" };

    // Aggregate metrics
    var totalRequests = Model.Count;
    var openRequests = Model.Count(m => m.Status <= 2); // Submitted, Assigned, InProgress
    var resolvedRequests = Model.Count(m => m.Status == 3 || m.Status == 4); // Resolved or Closed

    // Average resolution time (only for resolved/closed with DateResolved)
    var resolvedWithDates = Model.Where(m => m.DateResolved.HasValue).ToList();
    var avgResolutionDays = resolvedWithDates.Any()
        ? resolvedWithDates.Average(m => (m.DateResolved!.Value - m.DateSubmitted).TotalDays)
        : 0;

    var urgentCount = Model.Count(m => m.Priority == 3);
    var highCount = Model.Count(m => m.Priority == 2);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Maintenance Report</h2>
    <span class="text-muted">Generated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</span>
</div>

<!-- Status Summary Cards -->
<div class="row g-3 mb-4">
    @for (int i = 0; i < statusNames.Length; i++)
    {
        var count = Model.Count(m => m.Status == i);
        <div class="col">
            <div class="card bg-@statusColors[i] text-white text-center shadow-sm">
                <div class="card-body py-3">
                    <h2 class="mb-0">@count</h2>
                    <small>@statusNames[i]</small>
                </div>
            </div>
        </div>
    }
</div>

<!-- Aggregate Metrics -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-dark border-4">
            <div class="card-body">
                <h6 class="text-muted">Total Requests</h6>
                <h3 class="mb-0">@totalRequests</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-warning border-4">
            <div class="card-body">
                <h6 class="text-muted">Open Requests</h6>
                <h3 class="mb-0">@openRequests</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-success border-4">
            <div class="card-body">
                <h6 class="text-muted">Resolution Rate</h6>
                <h3 class="mb-0">@(totalRequests > 0 ? ((double)resolvedRequests / totalRequests * 100).ToString("F1") : "0")%</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-info border-4">
            <div class="card-body">
                <h6 class="text-muted">Avg Resolution Time</h6>
                <h3 class="mb-0">@avgResolutionDays.ToString("F1") days</h3>
            </div>
        </div>
    </div>
</div>

<!-- Breakdown by Category & Priority -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-bold">By Category</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Category</th><th>Total</th><th>Open</th><th>Resolved</th></tr></thead>
                    <tbody>
                        @for (int i = 0; i < categoryNames.Length; i++)
                        {
                            var catItems = Model.Where(m => m.Category == i).ToList();
                            if (catItems.Any())
                            {
                                <tr>
                                    <td>@categoryNames[i]</td>
                                    <td><span class="badge bg-secondary">@catItems.Count</span></td>
                                    <td>@catItems.Count(m => m.Status <= 2)</td>
                                    <td>@catItems.Count(m => m.Status >= 3)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-bold">By Priority</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Priority</th><th>Total</th><th>Open</th><th>Resolved</th></tr></thead>
                    <tbody>
                        @for (int i = 0; i < priorityNames.Length; i++)
                        {
                            var prioItems = Model.Where(m => m.Priority == i).ToList();
                            if (prioItems.Any())
                            {
                                <tr>
                                    <td><span class="badge bg-@priorityColors[i]">@priorityNames[i]</span></td>
                                    <td>@prioItems.Count</td>
                                    <td>@prioItems.Count(m => m.Status <= 2)</td>
                                    <td>@prioItems.Count(m => m.Status >= 3)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Data Table -->
<div class="card shadow-sm">
    <div class="card-header bg-light fw-bold">All Maintenance Requests</div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Date Submitted</th>
                    <th>Date Resolved</th>
                    <th>Resolution Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.RequestId</td>
                        <td>@item.Title</td>
                        <td>@(item.Category < categoryNames.Length ? categoryNames[item.Category] : "Other")</td>
                        <td>
                            <span class="badge bg-@(item.Priority < priorityColors.Length ? priorityColors[item.Priority] : "secondary")">
                                @(item.Priority < priorityNames.Length ? priorityNames[item.Priority] : "Unknown")
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-@(item.Status < statusColors.Length ? statusColors[item.Status] : "secondary")">
                                @(item.Status < statusNames.Length ? statusNames[item.Status] : "Unknown")
                            </span>
                        </td>
                        <td>@item.DateSubmitted.ToString("dd MMM yyyy")</td>
                        <td>@(item.DateResolved.HasValue ? item.DateResolved.Value.ToString("dd MMM yyyy") : "-")</td>
                        <td>
                            @if (item.DateResolved.HasValue)
                            {
                                var days = (item.DateResolved.Value - item.DateSubmitted).TotalDays;
                                <span>@days.ToString("F0") days</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
