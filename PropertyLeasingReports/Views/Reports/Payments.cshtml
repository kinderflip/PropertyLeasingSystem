@model List<PropertyLeasingReports.Models.PaymentReport>
@{
    ViewData["Title"] = "Payments Report";
    // PaymentStatus: Pending=0, Completed=1, Overdue=2
    var statusNames = new[] { "Pending", "Completed", "Overdue" };
    var statusColors = new[] { "warning", "success", "danger" };
    var typeNames = new[] { "Rent", "Deposit", "Fine" };
    var typeColors = new[] { "primary", "info", "danger" };

    // Aggregate metrics
    var totalPayments = Model.Count;
    var pendingCount = Model.Count(p => p.Status == 0);
    var completedCount = Model.Count(p => p.Status == 1);
    var overdueCount = Model.Count(p => p.Status == 2);

    var totalCollected = Model.Where(p => p.Status == 1).Sum(p => p.Amount);
    var totalPending = Model.Where(p => p.Status == 0).Sum(p => p.Amount);
    var totalOverdue = Model.Where(p => p.Status == 2).Sum(p => p.Amount);
    var totalAmount = Model.Sum(p => p.Amount);

    var collectionRate = totalPayments > 0 ? (double)completedCount / totalPayments * 100 : 0;
    var avgPaymentAmount = Model.Any() ? Model.Average(p => p.Amount) : 0;

    // On-time payment rate (completed payments that were paid before or on due date)
    var completedPayments = Model.Where(p => p.Status == 1 && p.PaymentDate.HasValue).ToList();
    var onTimePayments = completedPayments.Count(p => p.PaymentDate!.Value <= p.DueDate);
    var onTimeRate = completedPayments.Any() ? (double)onTimePayments / completedPayments.Count * 100 : 0;
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-warning">@ViewBag.Error</div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Payments Report</h2>
    <span class="text-muted">Generated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</span>
</div>

<!-- Status Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-dark text-white text-center shadow-sm">
            <div class="card-body">
                <h2>@totalPayments</h2>
                <p class="mb-0">Total Payments</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white text-center shadow-sm">
            <div class="card-body">
                <h2>@completedCount</h2>
                <p class="mb-0">Completed</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white text-center shadow-sm">
            <div class="card-body">
                <h2>@pendingCount</h2>
                <p class="mb-0">Pending</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white text-center shadow-sm">
            <div class="card-body">
                <h2>@overdueCount</h2>
                <p class="mb-0">Overdue</p>
            </div>
        </div>
    </div>
</div>

<!-- Financial Metrics -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-success border-4">
            <div class="card-body">
                <h6 class="text-muted">Total Collected</h6>
                <h3 class="mb-0 text-success">@totalCollected.ToString("N3") BD</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-warning border-4">
            <div class="card-body">
                <h6 class="text-muted">Pending Amount</h6>
                <h3 class="mb-0 text-warning">@totalPending.ToString("N3") BD</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-danger border-4">
            <div class="card-body">
                <h6 class="text-muted">Overdue Amount</h6>
                <h3 class="mb-0 text-danger">@totalOverdue.ToString("N3") BD</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-dark border-4">
            <div class="card-body">
                <h6 class="text-muted">Total Amount</h6>
                <h3 class="mb-0">@totalAmount.ToString("N3") BD</h3>
            </div>
        </div>
    </div>
</div>

<!-- Rate Metrics -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <h6 class="text-muted">Collection Rate</h6>
                <h2 class="mb-1">@collectionRate.ToString("F1")%</h2>
                <div class="progress" style="height: 8px;">
                    <div class="progress-bar bg-success" style="width: @collectionRate%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <h6 class="text-muted">On-Time Payment Rate</h6>
                <h2 class="mb-1">@onTimeRate.ToString("F1")%</h2>
                <div class="progress" style="height: 8px;">
                    <div class="progress-bar bg-info" style="width: @onTimeRate%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <h6 class="text-muted">Average Payment</h6>
                <h2 class="mb-1">@avgPaymentAmount.ToString("N3") BD</h2>
            </div>
        </div>
    </div>
</div>

<!-- Breakdown by Type -->
<div class="row g-3 mb-4">
    <div class="col-md-12">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-bold">By Payment Type</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Type</th><th>Count</th><th>Total Amount</th><th>Collected</th><th>Outstanding</th></tr></thead>
                    <tbody>
                        @for (int i = 0; i < typeNames.Length; i++)
                        {
                            var typePayments = Model.Where(p => p.PaymentType == i).ToList();
                            if (typePayments.Any())
                            {
                                <tr>
                                    <td><span class="badge bg-@typeColors[i]">@typeNames[i]</span></td>
                                    <td>@typePayments.Count</td>
                                    <td>@typePayments.Sum(p => p.Amount).ToString("N3") BD</td>
                                    <td class="text-success">@typePayments.Where(p => p.Status == 1).Sum(p => p.Amount).ToString("N3") BD</td>
                                    <td class="text-danger">@typePayments.Where(p => p.Status != 1).Sum(p => p.Amount).ToString("N3") BD</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Data Table -->
<div class="card shadow-sm">
    <div class="card-header bg-light fw-bold">All Payments</div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Lease ID</th>
                    <th>Amount</th>
                    <th>Due Date</th>
                    <th>Payment Date</th>
                    <th>Type</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var rowClass = item.Status == 2 ? "table-danger" : "";
                    <tr class="@rowClass">
                        <td>@item.PaymentId</td>
                        <td>@item.LeaseId</td>
                        <td>@item.Amount.ToString("N3") BD</td>
                        <td>@item.DueDate.ToString("dd MMM yyyy")</td>
                        <td>@(item.PaymentDate.HasValue ? item.PaymentDate.Value.ToString("dd MMM yyyy") : "-")</td>
                        <td>
                            <span class="badge bg-@(item.PaymentType < typeColors.Length ? typeColors[item.PaymentType] : "secondary")">
                                @(item.PaymentType < typeNames.Length ? typeNames[item.PaymentType] : "Unknown")
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-@(item.Status < statusColors.Length ? statusColors[item.Status] : "secondary")">
                                @(item.Status < statusNames.Length ? statusNames[item.Status] : "Unknown")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
