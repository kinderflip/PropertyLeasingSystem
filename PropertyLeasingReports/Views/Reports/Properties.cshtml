@model List<PropertyLeasingReports.Models.PropertyReport>
@{
    ViewData["Title"] = "Properties Report";
    var statusNames = new[] { "Available", "Leased", "Under Maintenance" };
    var typeNames = new[] { "Apartment", "Villa", "Shop", "Office" };
    var statusColors = new[] { "success", "warning", "danger" };

    // Aggregate metrics
    var totalProperties = Model.Count;
    var availableCount = Model.Count(p => p.Status == 0);
    var leasedCount = Model.Count(p => p.Status == 1);
    var maintenanceCount = Model.Count(p => p.Status == 2);
    var occupancyRate = totalProperties > 0 ? (double)leasedCount / totalProperties * 100 : 0;
    var avgRent = Model.Any() ? Model.Average(p => p.MonthlyRent) : 0;
    var totalPotentialRevenue = Model.Sum(p => p.MonthlyRent);
    var activeRevenue = Model.Where(p => p.Status == 1).Sum(p => p.MonthlyRent);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Properties Report</h2>
    <span class="text-muted">Generated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</span>
</div>

<!-- Status Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-success text-white text-center shadow-sm">
            <div class="card-body">
                <h2>@availableCount</h2>
                <p class="mb-0">Available</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white text-center shadow-sm">
            <div class="card-body">
                <h2>@leasedCount</h2>
                <p class="mb-0">Leased</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white text-center shadow-sm">
            <div class="card-body">
                <h2>@maintenanceCount</h2>
                <p class="mb-0">Under Maintenance</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark text-white text-center shadow-sm">
            <div class="card-body">
                <h2>@totalProperties</h2>
                <p class="mb-0">Total Properties</p>
            </div>
        </div>
    </div>
</div>

<!-- Aggregate Metrics -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-primary border-4">
            <div class="card-body">
                <h6 class="text-muted">Occupancy Rate</h6>
                <h3 class="mb-0">@occupancyRate.ToString("F1")%</h3>
                <div class="progress mt-2" style="height: 6px;">
                    <div class="progress-bar bg-primary" style="width: @occupancyRate%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-info border-4">
            <div class="card-body">
                <h6 class="text-muted">Average Monthly Rent</h6>
                <h3 class="mb-0">BD @avgRent.ToString("F2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-success border-4">
            <div class="card-body">
                <h6 class="text-muted">Active Monthly Revenue</h6>
                <h3 class="mb-0">BD @activeRevenue.ToString("F2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-start border-secondary border-4">
            <div class="card-body">
                <h6 class="text-muted">Total Potential Revenue</h6>
                <h3 class="mb-0">BD @totalPotentialRevenue.ToString("F2")</h3>
            </div>
        </div>
    </div>
</div>

<!-- Breakdown by Type & City -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-bold">By Property Type</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Type</th><th>Count</th><th>Avg Rent</th></tr></thead>
                    <tbody>
                        @for (int i = 0; i < typeNames.Length; i++)
                        {
                            var typeProps = Model.Where(p => p.PropertyType == i).ToList();
                            if (typeProps.Any())
                            {
                                <tr>
                                    <td>@typeNames[i]</td>
                                    <td><span class="badge bg-secondary">@typeProps.Count</span></td>
                                    <td>BD @typeProps.Average(p => p.MonthlyRent).ToString("F2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-bold">By City</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>City</th><th>Count</th><th>Avg Rent</th></tr></thead>
                    <tbody>
                        @foreach (var cityGroup in Model.GroupBy(p => p.City).OrderByDescending(g => g.Count()))
                        {
                            <tr>
                                <td>@cityGroup.Key</td>
                                <td><span class="badge bg-secondary">@cityGroup.Count()</span></td>
                                <td>BD @cityGroup.Average(p => p.MonthlyRent).ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Data Table -->
<div class="card shadow-sm">
    <div class="card-header bg-light fw-bold">All Properties</div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Address</th>
                    <th>City</th>
                    <th>Type</th>
                    <th>Bedrooms</th>
                    <th>Monthly Rent</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PropertyId</td>
                        <td>@item.Address</td>
                        <td>@item.City</td>
                        <td>@(item.PropertyType < typeNames.Length ? typeNames[item.PropertyType] : "Other")</td>
                        <td>@item.Bedrooms</td>
                        <td>BD @item.MonthlyRent.ToString("F2")</td>
                        <td>
                            <span class="badge bg-@(item.Status < statusColors.Length ? statusColors[item.Status] : "secondary")">
                                @(item.Status < statusNames.Length ? statusNames[item.Status] : "Unknown")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
